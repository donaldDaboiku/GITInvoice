{
    "name": "invohub/backend",
    "description": "InvoHubdb - PHP Backend API",
    "type": "project",
    "license": "proprietary",
    "authors": [
        {
            "name": "InvoHub",
            "email": "dev@invohub.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^7.0",
        "phpmailer/phpmailer": "^6.8",
        "stripe/stripe-php": "^12.0",
        "aws/aws-sdk-php": "^3.280",
        "phpoffice/phpspreadsheet": "^1.29",
        "dompdf/dompdf": "^2.0",
        "predis/predis": "^2.2",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.3",
        "fakerphp/faker": "^1.23"
    },
    "autoload": {
        "psr-4": {
            "InvoHub\\": "src/"
        },
        "files": [
            "src/Utils/helpers.php"
        ]
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php database/migrate.php",
        "serve": "php -S localhost:8000 -t public"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
