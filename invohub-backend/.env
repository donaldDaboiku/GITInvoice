# Application
APP_NAME=InvoHub
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.invohub.com
APP_TIMEZONE=UTC

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=invohubdb
DB_USERNAME=root
DB_PASSWORD=Olaorbit@84

# JWT
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRY=604800
JWT_REFRESH_EXPIRY=2592000

# Redis Cache
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DATABASE=0

# Email (SMTP)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@invohub.com
MAIL_FROM_NAME=InvoHub

# AWS S3 Storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=invohub-storage
AWS_USE_PATH_STYLE_ENDPOINT=false

# Stripe
STRIPE_PUBLIC_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Security
CORS_ALLOWED_ORIGINS=https://invohub.com,https://app.invohub.com
RATE_LIMIT_PER_MINUTE=60
MAX_LOGIN_ATTEMPTS=5
LOGIN_THROTTLE_MINUTES=15

# Features
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_2FA=true
MAX_FILE_SIZE=10485760

# Subscription Plans
PLAN_FREE_INVOICES=3
PLAN_STARTER_INVOICES=25
PLAN_PRO_INVOICES=0
PLAN_STARTER_PRICE=9
PLAN_PRO_PRICE=19
PLAN_ENTERPRISE_PRICE=49
